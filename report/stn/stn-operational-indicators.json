{
  "global": [
    {
      "id": "prazo-medio-conclusao-dias",
      "name": "Prazo médio de conclusão (dias)",
      "periodicity": "mensal",
      "formula": "media_dias(data_conclusao - data_abertura)"
    },
    {
      "id": "taxa-conclusao-no-prazo",
      "name": "Taxa de conclusão no prazo (%)",
      "periodicity": "mensal",
      "formula": "tarefas_concluidas_no_prazo / tarefas_concluidas * 100"
    },
    {
      "id": "taxa-retrabalho",
      "name": "Taxa de retrabalho (%)",
      "periodicity": "mensal",
      "formula": "tarefas_reabertas / tarefas_concluidas * 100"
    }
  ],
  "units": {
    "SUGEF": [
      {
        "id": "cobertura-alertas-fiscais",
        "name": "Cobertura de alertas fiscais tratados (%)",
        "periodicity": "mensal",
        "formula": "alertas_tratados / alertas_total * 100"
      }
    ],
    "SUAFI": [
      {
        "id": "conformidade-execucao-financeira",
        "name": "Conformidade da execução financeira (%)",
        "periodicity": "mensal",
        "formula": "eventos_conformes / eventos_total * 100"
      }
    ],
    "SUCON": [
      {
        "id": "tempestividade-fechamento-contabil",
        "name": "Tempestividade de fechamento contábil (%)",
        "periodicity": "mensal",
        "formula": "fechamentos_no_prazo / fechamentos_total * 100"
      }
    ]
  }
}
